{
  "name": "tiny-idb",
  "version": "1.6.1",
  "description": "An extremely fast, super simple, and dependency-free IndexedDB wrapper. A drop-in replacement for localStorage with reliability and durability.",
  "main": "tiny-idb.js",
  "module": "tiny-idb.js",
  "unpkg": "tiny-idb.min.js",
  "exports": {
    ".": "./tiny-idb.js",
    "./min": "./tiny-idb.min.js"
  },
  "types": "index.d.ts",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jelodar/tiny-idb.git"
  },
  "keywords": [
    "indexeddb",
    "storage",
    "localstorage",
    "simple",
    "wrapper",
    "db",
    "browser",
    "persistent",
    "nosql",
    "key-value",
    "typescript"
  ],
  "author": "Jelodar",
  "license": "MIT",
  "sideEffects": false,
  "engines": {
    "node": ">=16.0.0"
  },
  "bugs": {
    "url": "https://github.com/Jelodar/tiny-idb/issues"
  },
  "homepage": "https://github.com/Jelodar/tiny-idb#readme",
  "files": [
    "tiny-idb.js",
    "tiny-idb.min.js",
    "index.d.ts",
    "LICENSE",
    "README.md"
  ],
  "devDependencies": {
    "fake-indexeddb": "^6.2.5",
    "terser": "^5.46.1"
  },
  "scripts": {
    "test": "node test.js",
    "test:min": "TEST_MIN=1 node test.js",
    "build": "npm run minify",
    "minify": "terser tiny-idb.js -o tiny-idb.min.js -c toplevel,unsafe -m toplevel --comments '/tiny-idb/'"
  }
}
